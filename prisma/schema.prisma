generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// --- ENUMS ---

enum Role {
  ADMIN
  AUTHOR
  READER
}

enum AuthProvider {
  CREDENTIALS
  GOOGLE
}

enum UserStatus {
  ACTIVE
  BLOCKED
  BANNED
  DELETED
}

enum PostStatus {
  DRAFT
  PENDING
  PUBLISHED
  ARCHIVED
  REJECTED
}

enum CommentStatus {
  ACTIVE
  HIDDEN
  DELETED
}

// USER MODEL

model User {
  id         String     @id @default(cuid())
  name       String
  email      String     @unique
  password   String?
  image      String?
  role       Role       @default(READER)
  status     UserStatus @default(ACTIVE)
  isVerified Boolean    @default(false) // OTP 
  isDeleted  Boolean    @default(false) // Soft Delete
  deletedAt  DateTime?

  // RELATIONS
  authAccounts  AuthProviderAccount[]
  otps          OtpVerification[]
  devices       LoginDevice[]
  posts         Post[]
  comments      Comment[]
  sessions      ReadingSession[]
  refreshTokens RefreshToken[]
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  @@index([status])
  @@index([role])
}
