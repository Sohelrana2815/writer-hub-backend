generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// --- ENUMS ---

enum Role {
  ADMIN // CAN READ MANAGE ALL BLOGS AND USERS
  AUTHOR // CAN READ, POST AND MANGE OWN BLOGS AND PROFILE
  READER // ONLY READ AND CAN COMMENT
}

enum AuthProvider {
  CREDENTIALS
  GOOGLE
}

enum UserStatus {
  ACTIVE
  BLOCKED // Temporary Blocked
  BANNED // Permanently banned
  DELETED // Soft deleted
}

enum PostStatus {
  DRAFT
  PENDING
  PUBLISHED
  ARCHIVED
  REJECTED
}

enum CommentStatus {
  ACTIVE
  HIDDEN
  DELETED
}

// ============================================
// USER & AUTHENTICATION
// ============================================

model User {
  id         String     @id @default(cuid())
  name       String
  email      String     @unique
  password   String? // NULL for OAuth users
  image      String?
  role       Role       @default(READER)
  status     UserStatus @default(ACTIVE)
  isVerified Boolean    @default(false) // OTP verification
  // Soft Delete
  isDeleted  Boolean    @default(false)
  deletedAt  DateTime?

  // Relations
  authAccounts  AuthProviderAccount[]
  otps          OtpVerification[]
  devices       LoginDevice[]
  posts         Post[]
  comments      Comment[]
  sessions      ReadingSession[]
  refreshTokens RefreshToken[]
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  @@index([status])
  @@index([role])
}

// ============================================
// AUTH PROVIDER (OAuth Support)
// ============================================

model AuthProviderAccount {
  id           String       @id @default(cuid())
  userId       String
  provider     AuthProvider
  providerId   String? // Google User ID
  // ⚙️ DECISION POINT:
  // Uncomment these lines ONLY if you'll use Google APIs
  // (Calendar, Gmail, Drive, etc.)
  // 
  accessToken  String?      @db.Text
  refreshToken String?      @db.Text
  expiresAt    DateTime?
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@unique([provider, providerId])
  @@index([userId])
}

// ============================================
// OTP VERIFICATION (Email Verification)
// ============================================

model OtpVerification {
  id          String    @id @default(cuid())
  userId      String
  email       String
  otp         String // 6-digit code
  expiresAt   DateTime // Valid for 5 minutes
  isUsed      Boolean   @default(false)
  attempts    Int       @default(0)
  // Lock mechanism: 2-hour lock after 5 failed attempts
  lockedUntil DateTime?
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

// ============================================
// DEVICE TRACKING (Smart Login)
// ============================================

model LoginDevice {
  id            String         @id @default(cuid())
  userId        String
  deviceId      String // Browser fingerprint
  ipAddress     String
  userAgent     String         @db.Text
  isTrusted     Boolean        @default(false) // Trusted = No OTP needed
  lastLoginAt   DateTime       @default(now())
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshTokens RefreshToken[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@unique([userId, deviceId])
  @@index([userId])
  @@index([deviceId])
}

// ============================================
// JWT REFRESH TOKEN (Revocation Support)
// ============================================

model RefreshToken {
  id        String       @id @default(cuid())
  userId    String
  deviceId  String? // Device reference
  token     String       @unique @db.Text // JWT refresh token (hashed)
  expiresAt DateTime
  isRevoked Boolean      @default(false)
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  device    LoginDevice? @relation(fields: [deviceId], references: [id])
  createdAt DateTime     @default(now())

  @@index([userId])
  @@index([token])
  @@index([deviceId])
}

// ============================================
// BLOG CONTENT
// ============================================

model Post {
  id            String     @id @default(cuid())
  title         String
  slug          String     @unique
  excerpt       String     @db.VarChar(300)
  content       String     @db.Text
  featuredImage String?
  status        PostStatus @default(PENDING)

  // SEO Metadata
  metaTitle       String?  @db.VarChar(60)
  metaDescription String?  @db.VarChar(160)
  keywords        String[]
  // AI Metadata (Single JSON field - cleaner than 3 separate fields)
  // Structure: { generatedExcerpt, suggestedTags, suggestedCategory, generatedAt }
  aiMetadata      Json?

  // Reading Info
  readingTime Int    @default(5) // Minutes
  difficulty  String @default("Intermediate")
  viewCount   Int    @default(0)

  // Relations
  authorId        String
  author          User             @relation(fields: [authorId], references: [id], onDelete: Cascade)
  categoryId      String
  category        Category         @relation(fields: [categoryId], references: [id])
  tags            Tag[]
  comments        Comment[]
  readingSessions ReadingSession[]

  // Admin Moderation
  approvedAt      DateTime?
  approvedBy      String? // Admin user ID
  rejectedAt      DateTime?
  rejectedBy      String? // Admin user ID
  rejectionReason String?   @db.Text
  // Soft Delete
  isDeleted       Boolean   @default(false)
  deletedAt       DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([authorId])
  @@index([categoryId])
  @@index([status])
  @@index([createdAt])
  @@index([viewCount])
}

// ============================================
// CATEGORY (Minimalist - Essential Fields Only)
// ============================================

model Category {
  id          String  @id @default(cuid())
  name        String  @unique
  slug        String  @unique
  description String? @db.VarChar(160) // For SEO
  icon        String?
  color       String?
  posts       Post[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@index([slug])
}

// ============================================
// TAG (Separate Table for Flexibility)
// ============================================

model Tag {
  id    String @id @default(cuid())
  name  String @unique // "nextjs"
  slug  String @unique // "nextjs"
  posts Post[]

  createdAt DateTime @default(now())

  @@index([slug])
}

// ============================================
// COMMENTS (Nested Replies Support)
// ============================================

model Comment {
  id      String        @id @default(cuid())
  content String        @db.Text
  status  CommentStatus @default(ACTIVE)

  postId   String
  post     Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId String
  author   User   @relation(fields: [authorId], references: [id], onDelete: Cascade)

  // Nested Replies (Self-referential)
  parentId String?
  parent   Comment?  @relation("Replies", fields: [parentId], references: [id], onDelete: Cascade)
  replies  Comment[] @relation("Replies")

  // Soft Delete
  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([postId])
  @@index([authorId])
  @@index([parentId])
  @@index([status])
}

// ============================================
// READING ANALYTICS
// ============================================

model ReadingSession {
  id           String    @id @default(cuid())
  userId       String
  postId       String
  duration     Int       @default(0) // Seconds
  progress     Int       @default(0) // 0-100%
  startedAt    DateTime  @default(now())
  lastActiveAt DateTime  @default(now()) // Last Read at 
  completedAt  DateTime?

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  updatedAt DateTime @updatedAt

  @@unique([userId, postId])
  @@index([userId])
  @@index([postId])
}
